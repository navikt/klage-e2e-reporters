{
  "name": "@navikt/klage-e2e-reporters",
  "version": "1.3.3",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./slack": {
      "import": { "types": "./dist/slack-reporter.d.mts", "default": "./dist/slack-reporter.mjs" },
      "require": { "types": "./dist/slack-reporter.d.cts", "default": "./dist/slack-reporter.cjs" }
    },
    "./status": {
      "import": { "types": "./dist/status-reporter.d.mts", "default": "./dist/status-reporter.mjs" },
      "require": { "types": "./dist/status-reporter.d.cts", "default": "./dist/status-reporter.cjs" }
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsdown --config-loader native",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "knip": "knip"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "dependencies": {
    "@slack/bolt": "4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playwright/test": "1.52.0",
    "@slack/web-api": "7.9.3",
    "@types/node": "22.15.17",
    "knip": "6.12.2",
    "tsdown": "0.22.0",
    "typescript": "5.8.3"
  }
}
